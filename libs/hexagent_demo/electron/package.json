{
  "name": "clawwork",
  "version": "0.0.1",
  "description": "ClawWork Desktop App",
  "main": "main.js",
  "scripts": {
    "dev": "cross-env ELECTRON_DEV=1 electron .",
    "build:mac": "electron-builder --mac --arm64",
    "build:mac-x64": "electron-builder --mac --x64",
    "build:mac-universal": "electron-builder --mac --universal",
    "build:mac-all": "electron-builder --mac --arm64 --x64",
    "build:win": "electron-builder --win --x64",
    "build:win-arm64": "electron-builder --win --arm64",
    "build:all": "electron-builder --mac --win"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.clawwork.app",
    "productName": "ClawWork",
    "directories": {
      "buildResources": "resources",
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../frontend/dist",
        "to": "frontend"
      },
      {
        "from": "backend_dist/",
        "to": "backend"
      }
    ],
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "signIgnore": [],
      "extraResources": [
        {
          "from": "lima_dist/",
          "to": "lima"
        }
      ]
    },
    "afterPack": "./scripts/afterPack.js",
    "win": {
      "extraResources": [
        {
          "from": "resources/wsl/",
          "to": "wsl"
        },
        {
          "from": "resources/icon.ico",
          "to": "app-icon.ico"
        }
      ],
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "include": "resources/installer.nsh"
    }
  }
}
